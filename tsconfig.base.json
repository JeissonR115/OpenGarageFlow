{
  "compilerOptions": {
    "paths": {},
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": true,
    "strictNullChecks": true,
    "noFallthroughCasesInSwitch": false,
    "strictBindCallApply": false,
    "incremental": true
  }
}
