# ==========================================================
# OpenGarageFlow API
# Environment Configuration
# ==========================================================

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------

NODE_ENV=development

APP_NAME=OpenGarageFlow API
APP_VERSION=0.1.0
API_VERSION=1

HOST=0.0.0.0
PORT=3001

LOG_LEVEL=debug

# Allowed origins separated by commas if needed.
# Example:
# CORS_ORIGIN=http://localhost:3000,http://localhost:5173
CORS_ORIGIN=http://localhost:3000

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------

DATABASE_URL=postgresql://admin:admin@localhost:5433/opengarageflow

# ----------------------------------------------------------
# Authentication
# ----------------------------------------------------------

JWT_SECRET=replace-with-a-secure-secret

JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=replace-with-a-secure-refresh-secret

JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------------------------
# Swagger
# ----------------------------------------------------------

SWAGGER_ENABLED=true
